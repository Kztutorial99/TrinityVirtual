<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TrinityVirtual" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/bg_surface</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:statusBarColor">@color/bg_base</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/bg_card</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="chipStyle">@style/Widget.Trinity.Chip</item>
    </style>

    <style name="Widget.Trinity.Chip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="android:textColor">@color/on_primary</item>
    </style>

    <style name="Theme.TrinityVirtual.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:statusBarColor">@color/bg_base</item>
        <item name="android:navigationBarColor">@color/bg_base</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.TrinityVirtual.Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/surface</item>
        <item name="colorPrimaryDark">@color/bg_surface</item>
        <item name="android:windowBackground">@color/bg_base</item>
    </style>
</resources>
